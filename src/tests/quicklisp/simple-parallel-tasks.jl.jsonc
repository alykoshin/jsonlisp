// quicklisp/simple-parallel-tasks: plist evaluates its branches in parallel.
{
  "$schema": "../../toplevel/activity.schema.json",
  "base_dir": ".",
  "version": "0.0.0",
  "actions": {
    "default": ["list",
      ["test-plist1"],
      ["test-plist2"],
      ["test-plist-result"],
      ["princ", "assert-x:\n  OK:   ${ assert_ok_count }\n  FAIL: ${ assert_fail_count }"]
    ],

    // plist returns the results of its branches, evaluated in parallel
    "test-plist-result": ["list",
      ["assert-equal",
        ["plist", ["+", 1, 2], ["+", 3, 4]],
        ["quote", [3, 7]]]
    ],

    "test-plist1": ["list",
      ["print", "plist-1"],
      ["plist",
        ["list",
          ["print", "series-2-parallel-1-series-1"],
          ["sleep", ["+", 0.1, 0.2, 0.7]],
          ["print", "series-2-parallel-1-series-2"]],
        ["list",
          ["print", "series-2-parallel-2-series-1"],
          ["sleep", ["*", 1, 1, 1]],
          ["print", "series-2-parallel-2-series-2"]]
      ]
    ],

    "test-plist2": ["list",
      ["print", "plist-2"],
      ["plist",
        ["list",
          ["print", "series-2-parallel-1-series-1"],
          ["sleep", 1],
          ["print", "series-2-parallel-1-series-2"]],
        ["list",
          ["print", "series-2-parallel-2-series-1"],
          ["sleep", 1],
          ["print", "series-2-parallel-2-series-2"]]]
    ],

    "printVersion": ["list",
      ["time",
        ["list",
          ["print", "Running in sequence"],
          ["list",
            ["shell-command", "node --version"],
            ["shell-command", "npm --version"],
            ["shell-command", "yarn --version"]
          ]
        ]
      ],
      ["time",
        ["list",
          ["print", "Running in parallel"],
          ["plist",
            ["shell-command", "node --version"],
            ["shell-command", "npm --version"],
            ["shell-command", "yarn --version"]
          ]
        ]
      ]
    ]
  }
}
