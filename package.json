{
  "name": "tools-runner",
  "version": "0.0.68",
  "description": "tools-runner",
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": "dist/cli.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "tools",
    "ARCHITECTURE.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "ts-node ./src/cli.ts tools/tools-runner.jl.jsonc",
    "start-js": "node ./dist/cli.js",
    "build": "npm start build",
    "test": "npm run check:layers && npm run test-core && npm run test:jl",
    "test-core": "ts-node ./src/tests/harness/core-test-runner.ts",
    "test:jl": "node ./scripts/run-jl-tests.js",
    "check:layers": "node ./scripts/check-layers.js",
    "start-activity-openssl": "ts-node ./src/cli.ts ./src/local-projects/openssl/index.jl.jsonc",
    "start-gen-certs": "ts-node ./src/cli.ts ./src/local-projects/openssl/index.jl.jsonc gen_all -f ./src/local-projects/openssl/examples/gen-certs.config.json",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alykoshin/tools-runner.git"
  },
  "keywords": [],
  "author": "alykoshin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alykoshin/tools-runner/issues"
  },
  "homepage": "https://github.com/alykoshin/tools-runner#readme",
  "dependencies": {
    "@utilities/object": "^0.4.4",
    "@utilities/string": "^0.1.1",
    "ajv": "^8.12.0",
    "archiver": "^6.0.1",
    "axios": "^1.5.1",
    "chalk": "4.1.2",
    "commander": "^11.0.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "git-config": "^0.0.7",
    "json5": "^2.2.3",
    "lodash": "^4.17.21",
    "mkdirp": "^3.0.1",
    "octokit": "^3.1.1",
    "semver": "^7.5.4",
    "shelljs": "^0.8.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.4",
    "@types/debug": "^4.1.9",
    "@types/ejs": "^3.1.3",
    "@types/git-config": "^0.0.30",
    "@types/lodash": "^4.14.199",
    "@types/node": "^20.8.3",
    "@types/semver": "^7.5.3",
    "@types/shelljs": "^0.8.13",
    "better-docs": "^2.7.2",
    "jsdoc": "^4.0.2",
    "prettier": "^3.0.3"
  },
  "packageManager": "yarn@3.6.3"
}
